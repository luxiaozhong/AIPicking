# ============================================================
# AIpicking 环境变量模板
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ============================================================

# 应用配置
APP_NAME=AIpicking
DEBUG=False

# 数据库配置（两种方式任选其一）
# 方式1：完整连接 URL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aipicking
# 方式2：分离组件（DATABASE_URL 为空时使用）
DB_USER=aipicking
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aipicking

# 同步数据库 URL（用于脚本/迁移，默认从 DATABASE_URL 自动推导）
# SYNC_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/aipicking

# CORS 配置（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173

# 回测数据目录
BACKTEST_DATA_DIR=./data/market_data

# JWT 密钥（生产环境务必设置随机字符串，至少 32 字符）
# 生成方式: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key-change-me

# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT=120

# 股票数据库路径（mootdx 本地缓存）
STOCK_DB_PATH=/opt/stock_data/stock_db.sqlite

# 默认管理员密码（仅首次创建时生效，未设置则自动生成随机密码）
# ADMIN_DEFAULT_PASSWORD=

# ============================================================
# 语音播报（老人微信链接入口）
# ============================================================
# 播报访问 token（逗号分隔，格式 label:token），URL 形如 /voice/<token>
# 生成示例: python -c "import secrets; print(secrets.token_urlsafe(16))"
VOICE_TOKENS=elder:change-me-to-a-random-token
# 老人关注列表对应的 index 代码（独立，不复用 900002）
VOICE_WATCHLIST_INDEX=900099
VOICE_WATCHLIST_NAME=语音播报关注
# Edge-TTS 音色（zh-CN-XiaoxiaoNeural 女声 / zh-CN-YunxiNeural 男声）
VOICE_TTS_VOICE=zh-CN-XiaoxiaoNeural
# 实时报价源（默认 tencent 腾讯财经，免费免鉴权）
VOICE_QUOTE_SOURCE=tencent
# 点开页面后自动刷新间隔（秒）
VOICE_REFRESH_SECONDS=30
